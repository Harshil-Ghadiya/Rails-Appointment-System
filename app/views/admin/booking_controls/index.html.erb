<%= turbo_frame_tag "main_content" do %>
<div style="display: flex;">
  <div style="margin-left: 50px; padding: 30px; flex: 1;">
    <h3 style="color: #2c3e50;"> Weekly Booking Schedule</h3>
    <p style="color: #7f8c8d;">Set opening and closing hours for each day.</p>

    <div style="background: white; border-radius: 10px; box-shadow: 0 4px 6px rgba(0,0,0,0.05); overflow: hidden;">
      <table style="width: 100%; border-collapse: collapse; text-align: left;">
        <tr style="background: #f8f9fa; border-bottom: 2px solid #eee;">
          <th style="padding: 15px;">Day</th>
          <th>Prefix</th>
          <th style="color: #181a1c;">Morning (Start - End)</th>     
          <th style="color: #e67e22;">Evening (Start - End)</th>   
          <th>Action</th>
        </tr>
        
        <% @booking_controls.each do |control| %>
        <%= render 'booking_row', control: control %>
  <% end %>
      </table>
    </div>
  </div>
</div>
<% end %>

