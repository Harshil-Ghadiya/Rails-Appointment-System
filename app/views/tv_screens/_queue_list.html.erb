<div id="tv_token_list">
  <% 
    current_time = Time.zone.now
    today_name = current_time.strftime("%A")
    ctrl = organization.booking_controls.find_by(day_name: today_name)

    if ctrl.present?
      current_time_str = current_time.strftime("%H:%M")
      evening_start = ctrl.evening_start_time.strftime("%H:%M")
      session_now = (current_time_str < evening_start) ? "Morning" : "Evening"

      apps = organization.appointments
                         .where(status: 0, session_name: session_now)
                         .where(created_at: current_time.all_day)
                         .order(:token_number_only)
                         .limit(10)
    else
      apps = []
      session_now = "No Control Set"
    end
  %>

  <div style="width: 95%; margin: auto; margin-top: 20px;">
    <table style="width: 100%; border-collapse: separate; border-spacing: 0 10px;">
      <thead>
        <tr style="font-size: 20px; color: #7f8c8d; text-align: left; text-transform: uppercase; letter-spacing: 1px;">
          <th style="padding: 10px 30px; width: 20%;">Token</th>
          <th style="padding: 10px 30px; width: 50%;">Patient Name</th>
          <th style="padding: 10px 30px; width: 30%;">Status</th>
        </tr>
      </thead>
      <tbody>
        <% if apps.any? %>
          <% apps.each_with_index do |app, index| %>
            <%# Row sizes: Current (Index 0) thodi highlight, baki badhi normal %>
            <tr style="background: <%= index == 0 ? '#27ae60' : '#2c3e50' %>; 
                       font-size: <%= index == 0 ? '38px' : '28px' %>; 
                       color: white; border-radius: 12px; transition: all 0.3s ease;">
              
              <td style="padding: 15px 30px; border-radius: 12px 0 0 12px; font-weight: bold; border-left: 6px solid <%= index == 0 ? '#f1c40f' : 'transparent' %>;">
                <%= app.token_number %>
              </td>

              <td style="padding: 15px 30px; text-transform: uppercase; font-weight: 500; letter-spacing: 0.5px;">
                <%= app.patient_name %>
              </td>

              <td style="padding: 15px 30px; border-radius: 0 12px 12px 0;">
                <% if index == 0 %>
                  <span style="background: #ffffff; color: #27ae60; padding: 4px 18px; border-radius: 20px; font-weight: bold; font-size: 18px; vertical-align: middle; display: inline-block;">
                    ● CURRENT
                  </span>
                <% else %>
                  <span style="color: #bdc3c7; font-size: 16px; font-weight: bold; text-transform: uppercase;">
                    Waiting
                  </span>
                <% end %>
              </td>
            </tr>
          <% end %>
        <% else %>
          <tr>
            <td colspan="3" style="text-align: center; padding-top: 80px;">
              <div style="font-size: 60px; margin-bottom: 10px;">☕</div>
              <h2 style="font-size: 32px; color: #bdc3c7; margin: 0;">No Patients in <%= session_now %> Queue</h2>
              <p style="font-size: 18px; color: #7f8c8d; margin-top: 10px;">
                Everything is up to date • <%= current_time.strftime("%I:%M %p") %>
              </p>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>